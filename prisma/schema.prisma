generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Bouquet {
  id            String          @id @default(cuid())
  slug          String          @unique
  status        String          @default("draft") // draft, sent, viewed
  senderName    String?
  recipientName String?
  noteText      String?
  noteFont      String          @default("serif")
  textColor     String          @default("#4a4a4a")
  backgroundId  String?
  musicId       String?
  bgColor       String          @default("#fdf6f0")
  bgImage       String?
  views         Int             @default(0)
  createdAt     DateTime        @default(now())
  viewedAt      DateTime?
  expiresAt     DateTime?
  userId        String?
  isPublic      Boolean         @default(true)
  wrapStyle     String?
  ribbonColor   String?
  occasion      String?
  noteCardStyle String?
  themeName     String?

  flowers       BouquetFlower[]
  user          User?           @relation(fields: [userId], references: [id])

  @@index([slug])
}

model BouquetFlower {
  id            String      @id @default(cuid())
  bouquetId     String
  flowerAssetId String
  positionX     Float       @default(50.0) // percentage
  positionY     Float       @default(50.0) // percentage
  rotation      Float       @default(0.0)
  scale         Float       @default(1.0)
  zIndex        Int         @default(1)
  colorVariant  String?

  bouquet       Bouquet     @relation(fields: [bouquetId], references: [id], onDelete: Cascade)
  flowerAsset   FlowerAsset @relation(fields: [flowerAssetId], references: [id])

  @@index([bouquetId])
  @@index([flowerAssetId])
}

model FlowerAsset {
  id          String          @id @default(cuid())
  name        String
  category    String
  colorTag    String?
  meaningTag  String?
  imagePath   String

  bouquets    BouquetFlower[]
  
  @@index([category])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  featuredImage String?
  category      String
  tags          String   // Stored as JSON string
  publishedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         Int      @default(0)
  
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
}

// ───────── Auth (NextAuth / Auth.js) ─────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed, for email/password sign-in
  accounts      Account[]
  sessions      Session[]
  bouquets      Bouquet[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Template {
  id          String  @id @default(cuid())
  occasion    String
  flowers     String  // Stored as JSON string
  note        String
  fromName    String?
  font        String  @default("serif")
  textColor   String  @default("#4a4a4a")
  music       String?
  bgColor     String  @default("#fdf6f0")
  isFeatured  Boolean @default(false)
}
