generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Bouquet {
  id          String   @id @default(cuid())
  slug        String   @unique
  flowers     String   // SQLite doesn't natively support JSON in older versions of Prisma but Prisma handles it. Let's stick to String and parse it in the API. Wait, Prisma supports Json on SQLite now? Yes, but just to be safe, String is better if it fails. Actually, Prisma *does* support String. Let's use String for flowers and parse it.
  note        String?
  fromName    String?
  font        String   @default("serif")
  textColor   String   @default("#4a4a4a")
  music       String?
  bgColor     String   @default("#fdf6f0")
  bgImage     String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  isPublic    Boolean  @default(true)
  
  @@index([slug])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  featuredImage String?
  category      String
  tags          String   // Stored as JSON string
  publishedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         Int      @default(0)
  
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
}

model Template {
  id          String  @id @default(cuid())
  occasion    String
  flowers     String  // Stored as JSON string
  note        String
  fromName    String?
  font        String  @default("serif")
  textColor   String  @default("#4a4a4a")
  music       String?
  bgColor     String  @default("#fdf6f0")
  isFeatured  Boolean @default(false)
}
