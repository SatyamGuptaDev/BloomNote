generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Bouquet {
  id          String   @id @default(cuid())
  slug        String   @unique
  flowers     String   // SQLite doesn't natively support JSON in older versions of Prisma but Prisma handles it. Let's stick to String and parse it in the API. Wait, Prisma supports Json on SQLite now? Yes, but just to be safe, String is better if it fails. Actually, Prisma *does* support String. Let's use String for flowers and parse it.
  note        String?
  fromName    String?
  font        String   @default("serif")
  textColor   String   @default("#4a4a4a")
  music       String?
  bgColor     String   @default("#fdf6f0")
  bgImage     String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  isPublic    Boolean  @default(true)
  
  @@index([slug])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  featuredImage String?
  category      String
  tags          String   // Stored as JSON string
  publishedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         Int      @default(0)
  
  @@index([slug])
  @@index([category])
  @@index([publishedAt])
}

// ───────── Auth (NextAuth / Auth.js) ─────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed, for email/password sign-in
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Template {
  id          String  @id @default(cuid())
  occasion    String
  flowers     String  // Stored as JSON string
  note        String
  fromName    String?
  font        String  @default("serif")
  textColor   String  @default("#4a4a4a")
  music       String?
  bgColor     String  @default("#fdf6f0")
  isFeatured  Boolean @default(false)
}
